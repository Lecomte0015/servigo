# ─── Database (Supabase / PostgreSQL) ──────────────────────────────────────────
# Supabase → Project Settings → Database → Connection string
# DATABASE_URL : Transaction Pooler port 6543, pgbouncer=true (Vercel serverless)
# DIRECT_URL   : connexion directe port 5432 (prisma migrate / prisma generate)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# ─── JWT & Chiffrement ──────────────────────────────────────────────────────────
# openssl rand -base64 64
JWT_SECRET="generate-with: openssl rand -base64 64"
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="64-hex-chars"

# ─── Stripe ─────────────────────────────────────────────────────────────────────
# Optionnel en dev. Requis en prod pour les paiements.
STRIPE_SECRET_KEY="sk_live_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Resend (emails transactionnels) ────────────────────────────────────────────
# https://resend.com → API Keys. Laisser vide = fallback log (dev uniquement)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# ─── Supabase Storage (photos artisans / catégories) ────────────────────────────
# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── Upstash Redis (rate limiting + session revocation) ─────────────────────────
# https://console.upstash.com → Redis → Create database
# REQUIS en prod multi-instance (Vercel). Fallback in-memory si absent.
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# ─── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
NODE_ENV="production"

# ─── Logs (optionnel) ────────────────────────────────────────────────────────────
# debug | info | warn | error  (défaut: info en prod)
# LOG_LEVEL="info"

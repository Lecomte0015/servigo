# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/servigo?schema=public"

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET="generate-with: openssl rand -base64 64"

# ─── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Supabase Storage ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── Upstash Redis (rate limiting — optionnel en dev) ──────────────────────────
# Créer un compte sur https://console.upstash.com → Redis → Create database
# Laisser vide pour utiliser le fallback in-memory (dev / instance unique)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
